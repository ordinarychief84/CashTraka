// CashTraka — WhatsApp Sales & Cash Tracker + Property Manager
// Prisma schema. Provider is sqlite for easy local dev; swap to postgresql for prod.
// To deploy against Postgres:
//   1) Change `provider = "sqlite"` to `provider = "postgresql"` below.
//   2) Set DATABASE_URL to your Postgres connection string (see .env.postgres.example).
//   3) Run `npx prisma migrate deploy` (or `prisma migrate dev --name whatever` in dev).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- USER ----------

model User {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  passwordHash         String
  businessName         String?
  whatsappNumber       String?
  receiptFooter        String?
  /// "seller" (default) or "property_manager"
  businessType         String    @default("seller")
  /// "free" | "business" | "business_plus" | "landlord" | "estate_manager"
  plan                 String    @default("free")
  /// "USER" (default) or "ADMIN". Admins access /admin.
  role                 String    @default("USER")
  /// Suspended users cannot log in.
  isSuspended          Boolean   @default(false)
  /// Timestamp of last successful login (for audit + analytics).
  lastLoginAt          DateTime?

  bankName             String?
  bankAccountNumber    String?
  bankAccountName      String?

  /// Address line shown on invoices.
  businessAddress      String?
  /// URL of the seller's logo (uploaded via Cloudinary) — printed on receipts & invoices.
  logoUrl              String?

  /// Billing state. `plan` (above) is the *tier name*; these fields describe
  /// the subscription lifecycle around that tier.
  /// "free" | "trialing" | "active" | "past_due" | "cancelled"
  subscriptionStatus       String    @default("free")
  /// End of the 14-day trial, if we started one. null if never trialled.
  trialEndsAt              DateTime?
  /// End of the current paid period (renewal date, or cancelled-grace boundary).
  currentPeriodEnd         DateTime?
  /// Paystack identifiers (stored once on first successful charge).
  paystackCustomerCode     String?
  paystackSubscriptionCode String?
  /// The plan the user picked at checkout; cleared when the webhook confirms.
  pendingPlan              String?

  /// Personal-expense thresholds (naira). When the owner's personal spending
  /// in the current week / month crosses either number, the dashboard
  /// surfaces a warning banner. Both are optional — leave null to disable.
  personalBudgetWeekly     Int?
  personalBudgetMonthly    Int?

  onboardingCompleted  Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  customers            Customer[]
  payments             Payment[]
  debts                Debt[]
  products             Product[]
  expenses             Expense[]
  templates            MessageTemplate[]
  fraudReports         FraudReport[]
  invoices             Invoice[]
  reminderSchedules    ReminderSchedule[]
  properties           Property[]
  tenants              Tenant[]
  rentPayments         RentPayment[]
  staffMembers         StaffMember[]
  attendance           Attendance[]
  staffPayments        StaffPayment[]
  tasks                Task[]
  checklists           Checklist[]
  checklistRuns        ChecklistRun[]
  receipts             Receipt[]
  adminNotesAuthored   AdminNote[]       @relation("AdminNoteAuthor")
  adminNotesReceived   AdminNote[]       @relation("AdminNoteTarget")
  paymentAttempts      PaymentAttempt[]

  @@index([role])
  @@index([businessType])
  @@index([isSuspended])
  @@index([lastLoginAt])
}

// ---------- CORE: customers, payments, debts ----------

model Customer {
  id               String    @id @default(cuid())
  userId           String
  name             String
  phone            String
  totalPaid        Int       @default(0)
  totalOwed        Int       @default(0)
  transactionCount Int       @default(0)
  lastActivityAt   DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments         Payment[]
  debts            Debt[]
  invoices         Invoice[]

  @@unique([userId, phone])
  @@index([userId])
  @@index([phone])
}

model Payment {
  id                   String    @id @default(cuid())
  userId               String
  customerId           String
  customerNameSnapshot String
  phoneSnapshot        String
  amount               Int
  status               String    @default("PAID")
  createdAt            DateTime  @default(now())

  referenceCode        String?   @unique
  verified             Boolean   @default(false)
  verifiedAt           DateTime?
  verificationMethod   String?
  bankAlertText        String?
  bankAlertSenderName  String?
  bankAlertBank        String?
  claimedAt            DateTime?

  /// If this payment was created from an invoice, link back.
  invoiceId            String?

  /// Whether a receipt was auto-sent after verification.
  receiptSentAt        DateTime?

  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer             Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items                PaymentItem[]
  invoice              Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, verified])
}

model PaymentItem {
  id          String   @id @default(cuid())
  paymentId   String
  productId   String?
  description String
  unitPrice   Int
  quantity    Int      @default(1)

  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([paymentId])
}

model Debt {
  id                   String    @id @default(cuid())
  userId               String
  customerId           String
  customerNameSnapshot String
  phoneSnapshot        String
  amountOwed           Int
  amountPaid           Int       @default(0)
  dueDate              DateTime?
  status               String    @default("OPEN")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer             Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reminderSchedules    ReminderSchedule[]

  @@index([userId, status])
}

// ---------- PRODUCTS ----------

model Product {
  id          String    @id @default(cuid())
  userId      String
  name        String
  price       Int
  cost        Int?
  stock       Int       @default(0)
  trackStock  Boolean   @default(true)
  lowStockAt  Int       @default(3)
  note        String?
  archived    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       PaymentItem[]
  invoiceItems InvoiceItem[]

  @@index([userId, archived])
}

// ---------- EXPENSES ----------

model Expense {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  category    String
  note        String?
  /// "business" (default) or "personal" — lets the owner track
  /// out-of-pocket personal spending alongside the business books.
  /// Personal expenses never show up in profit reports.
  kind        String   @default("business")
  incurredOn  DateTime @default(now())
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, incurredOn])
  @@index([userId, kind, incurredOn])
}

// ---------- MESSAGING ----------

model MessageTemplate {
  id          String   @id @default(cuid())
  userId      String
  name        String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- FRAUD ----------

model FraudReport {
  id         String   @id @default(cuid())
  userId     String
  phone      String
  reason     String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phone])
  @@index([phone])
}

// ---------- INVOICES ----------

/// A formal invoice the seller can generate and share before or after payment.
/// Public at /invoice/[invoiceNumber].
model Invoice {
  id              String    @id @default(cuid())
  userId          String
  customerId      String?
  /// Human-readable number like "INV-00042".
  invoiceNumber   String    @unique
  customerName    String
  customerPhone   String
  customerEmail   String?
  /// "DRAFT" | "SENT" | "PAID" | "CANCELLED"
  status          String    @default("DRAFT")
  subtotal        Int       @default(0)
  tax             Int       @default(0)
  total           Int       @default(0)
  note            String?
  dueDate         DateTime?
  issuedAt        DateTime  @default(now())
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items           InvoiceItem[]
  payments        Payment[]

  @@index([userId, status])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String?
  description String
  unitPrice   Int
  quantity    Int      @default(1)

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
}

// ---------- REMINDERS ----------

/// A scheduled reminder linked to a Debt. The system surfaces which reminders are
/// "due today" so the seller can one-tap send them all in WhatsApp.
model ReminderSchedule {
  id          String    @id @default(cuid())
  userId      String
  debtId      String
  /// "daily" | "every_3_days" | "weekly" | "custom"
  frequency   String    @default("weekly")
  /// Custom: number of days between reminders. Used when frequency=custom.
  intervalDays Int      @default(7)
  nextDueAt   DateTime
  lastSentAt  DateTime?
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  debt        Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([userId, nextDueAt])
}

// ---------- PROPERTY MANAGEMENT ----------

/// A property (building / compound) owned or managed by the user.
model Property {
  id            String    @id @default(cuid())
  userId        String
  name          String
  address       String?
  unitCount     Int       @default(0)
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenants       Tenant[]

  @@index([userId])
}

/// A tenant occupying a unit in a Property.
model Tenant {
  id            String    @id @default(cuid())
  userId        String
  propertyId    String
  name          String
  phone         String
  unitLabel     String?
  /// Monthly rent in Naira.
  rentAmount    Int
  /// Day of month rent is due (1-28).
  rentDueDay    Int       @default(1)
  /// "monthly" | "quarterly" | "yearly"
  rentFrequency String    @default("monthly")
  leaseStart    DateTime?
  leaseEnd      DateTime?
  /// "active" | "moved_out" | "evicted"
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  rentPayments  RentPayment[]

  @@index([userId, status])
}

/// Tracks each rent payment (or partial) for a tenant in a given period.
model RentPayment {
  id           String    @id @default(cuid())
  userId       String
  tenantId     String
  amount       Int
  /// The calendar month this covers, e.g. "2026-04".
  period       String
  /// "PAID" | "PARTIAL" | "PENDING" | "OVERDUE"
  status       String    @default("PENDING")
  verified     Boolean   @default(false)
  paidAt       DateTime?
  note         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, period])
  @@index([userId, period])
}

// ---------- TEAM, ATTENDANCE & PAYROLL ----------
//
// Nigerian SMB payroll realities shape this model:
//   - Staff are paid on fixed cycles (monthly for shop attendants, daily for
//     casual labour, per-task for tailors/drivers) — NOT hourly.
//   - Attendance is day-level: "did they show up?", not minute-level tracking.
//   - Salary advances mid-cycle are extremely common.
//   - Employers collect next-of-kin + bank details at hire.

/// A staff member / helper who works for the seller.
model StaffMember {
  id          String    @id @default(cuid())
  userId      String
  name        String
  phone       String?
  /// 4-6 digit PIN — optional, for situations where staff self-mark attendance on a shared device.
  pin         String?
  /// Human-readable job title ("Shop attendant", "Cashier", "Delivery").
  role        String?

  /// ── Login + RBAC ─────────────────────────────────────────────────────
  /// Unique email staff uses to log in. Optional — staff without login
  /// are just payroll records (the original behaviour). Unique per OWNER;
  /// different owners can have staff with the same email.
  email                String?
  /// Bcrypt hash. Null until staff accepts their invite.
  passwordHash         String?
  /// In-app permission level: "NONE" | "MANAGER" | "CASHIER" | "VIEWER".
  /// NONE means the staff cannot log in at all — they're just a payroll record.
  accessRole           String    @default("NONE")
  /// URL-safe random token the owner sends to the staff. Staff clicks it
  /// to set their password. Null after acceptance.
  inviteToken          String?   @unique
  inviteExpiresAt      DateTime?
  lastLoginAt          DateTime?

  /// Pay cycle: "monthly" | "weekly" | "daily" | "per_task"
  payType     String    @default("monthly")
  /// Pay amount in naira (whole numbers, matching the rest of the app).
  payAmount   Int       @default(0)

  /// When this person joined. Drives tenure + prorated first-month salary.
  startDate   DateTime?

  /// Bank details for salary transfer (optional).
  bankName             String?
  bankAccountNumber    String?
  bankAccountName      String?

  /// Next-of-kin details — standard Nigerian employment practice.
  nextOfKinName        String?
  nextOfKinPhone       String?

  /// Free-form notes (ID card no., referee, guarantor, etc.).
  notes       String?

  /// "active" | "inactive" (terminated, left).
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendance    Attendance[]
  staffPayments StaffPayment[]
  tasks         Task[]

  @@unique([userId, email])
  @@index([userId, status])
  @@index([email])
}

/// One row per (staff, date). Lets the owner mark whether someone turned up
/// that day. For daily-wage staff this is what payroll multiplies by.
model Attendance {
  id        String   @id @default(cuid())
  userId    String
  staffId   String
  /// Normalised to midnight UTC so uniqueness works cleanly.
  date      DateTime
  /// "present" | "absent" | "half_day" | "leave"
  status    String   @default("present")
  note      String?
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([userId, date])
}

/// Every payment the owner makes to a staff member. Salary is the big one,
/// but advances / bonuses / commissions / reimbursements are all first-class.
model StaffPayment {
  id           String    @id @default(cuid())
  userId       String
  staffId      String
  /// "salary" | "advance" | "bonus" | "commission" | "reimbursement"
  kind         String
  /// Amount in naira.
  amount       Int
  /// Pay period this payment covers (optional — used for salary).
  periodStart  DateTime?
  periodEnd    DateTime?
  note         String?
  paidAt       DateTime  @default(now())
  createdAt    DateTime  @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([userId, paidAt])
  @@index([staffId, paidAt])
}

// ---------- TASK MANAGEMENT ----------

/// A task assigned to self or a staff member.
model Task {
  id           String    @id @default(cuid())
  userId       String
  title        String
  description  String?
  assignedToId String?
  customerId   String?
  priority     String    @default("normal")
  status       String    @default("todo")
  dueDate      DateTime?
  completedAt  DateTime?
  /// Who marked the task done — either the owner (when OWNER finishes
  /// their own task) or the assigned StaffMember. Stored as a union:
  ///   completedByKind = "owner" | "staff"
  ///   completedById   = User.id  | StaffMember.id
  /// Kept as free-text strings (no FK) so we don't complicate the schema
  /// with a polymorphic relation. The UI resolves it for display.
  completedByKind String?
  completedById   String?
  /// Optional short note the assignee leaves when completing. Shown to
  /// the owner as a lightweight completion report ("Delivered, paid cash").
  completionNote  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTo   StaffMember? @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([assignedToId, status])
}

// ---------- CHECKLISTS ----------

/// A reusable checklist template (e.g. "Daily Opening", "Delivery Prep").
model Checklist {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  category    String    @default("custom")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       ChecklistItem[]
  runs        ChecklistRun[]

  @@index([userId])
}

/// A single item in a Checklist template.
model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String
  label       String
  sortOrder   Int       @default(0)

  checklist   Checklist        @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  results     ChecklistResult[]

  @@index([checklistId])
}

/// A single execution of a Checklist (e.g. "Monday morning opening").
model ChecklistRun {
  id          String    @id @default(cuid())
  userId      String
  checklistId String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  completedBy String?
  createdAt   DateTime  @default(now())

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklist   Checklist         @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  results     ChecklistResult[]

  @@index([userId, checklistId])
}

/// The result of a single item within a ChecklistRun.
model ChecklistResult {
  id        String    @id @default(cuid())
  runId     String
  itemId    String
  checked   Boolean   @default(false)
  note      String?
  checkedAt DateTime?

  run       ChecklistRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  item      ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([runId])
}

// ---------- RECEIPTS ----------

/// A persisted receipt record. Created automatically when a payment is marked
/// PAID (and optionally when a debt is cleared). Stores the generated PDF URL
/// (on Cloudinary) and tracks email delivery status.
model Receipt {
  id             String    @id @default(cuid())
  userId         String
  customerId     String?
  paymentId      String?   @unique
  debtId         String?   @unique
  /// Human-readable number like "CT-00001", unique globally.
  receiptNumber  String    @unique
  /// Hosted PDF URL (Cloudinary). Optional — may be null if storage failed;
  /// the PDF can always be re-rendered on demand from the source records.
  pdfUrl         String?
  /// "GENERATED" | "EMAILED" | "FAILED"
  status         String    @default("GENERATED")
  emailedTo      String?
  emailedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}

// ---------- ADMIN ----------

/// A free-form note written by an admin about a user (for audit trail).
model AdminNote {
  id            String   @id @default(cuid())
  adminUserId   String
  targetUserId  String
  note          String
  createdAt     DateTime @default(now())

  author        User     @relation("AdminNoteAuthor", fields: [adminUserId],  references: [id], onDelete: Cascade)
  target        User     @relation("AdminNoteTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([targetUserId, createdAt])
}

/// A key-value store for system-level configuration (feature flags, banners, etc.).
/// Value is JSON-stringified so it can hold any shape.
model SystemSetting {
  id         String   @id @default(cuid())
  key        String   @unique
  value      String
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

// ────────────────────────── BILLING ──────────────────────────

/// One row per Paystack checkout attempt. We create it in `pending` state when
/// the user clicks Upgrade, then mark `success`/`failed`/`abandoned` when the
/// outcome is known (via webhook or /api/billing/verify).
model PaymentAttempt {
  id                String   @id @default(cuid())
  userId            String
  targetPlan        String
  /// Amount charged, in kobo (100 kobo = 1 NGN).
  amount            Int
  currency          String   @default("NGN")
  /// Our generated reference sent to Paystack — unique across users.
  paystackReference String   @unique
  /// "pending" | "success" | "failed" | "abandoned"
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}

/// Raw Paystack webhook events, stored for audit and deduplication. The unique
/// constraint on `paystackEventId` means replays are no-ops.
model BillingEvent {
  id              String   @id @default(cuid())
  paystackEventId String   @unique
  eventType       String
  payloadJson     String
  processedAt     DateTime @default(now())
}
