# CashTraka — Postgres template
#
# Production deployments should use Postgres. Steps:
#  1) In prisma/schema.prisma, change `provider = "sqlite"` to `provider = "postgresql"`.
#  2) Copy this file to `.env` and fill in real values.
#  3) Run: npx prisma migrate deploy
#  4) Seed:  npm run db:seed   (optional)

# Postgres connection string (Supabase, Neon, Railway, local, etc.)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cashtraka?schema=public"

# Generate with: openssl rand -base64 32
AUTH_SECRET=""

APP_URL="https://app.cashtraka.co"

# ─── Email (Resend) ───────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="CashTraka <receipts@mail.cashtraka.co>"

# ─── File storage (Uploadcare) ────────────────────────────────────────────
UPLOADCARE_PUBLIC_KEY=""
UPLOADCARE_SECRET_KEY=""

# ─── Billing (Paystack) ───────────────────────────────────────────────────
# Use live keys in production. The webhook secret must match the HMAC-SHA512
# signing key set in the Paystack dashboard (Settings → Webhooks).
PAYSTACK_SECRET_KEY="sk_live_..."
PAYSTACK_PUBLIC_KEY="pk_live_..."
PAYSTACK_WEBHOOK_SECRET=""
BILLING_REDIRECT_URL="https://app.cashtraka.co/billing/callback"
