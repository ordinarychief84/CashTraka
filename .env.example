# CashTraka — .env template
# Copy to .env and fill in real values for production. Local dev uses SQLite
# by default (see .env). For Postgres, see .env.postgres.example.

# ─── Core ──────────────────────────────────────────────────────────────────
# Local SQLite (default for quick start):
DATABASE_URL="file:./dev.db"

# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string-please"

# Full URL the app is served at. Used in outbound emails & receipt links.
APP_URL="http://localhost:3000"

# ─── Email (Resend) — required for sending receipts to customers ──────────
# Get a key at https://resend.com. Leave unset to disable outbound email
# (receipts will still generate; the app won't crash).
RESEND_API_KEY=""
# The "From" address Resend will deliver from (must be a verified sender).
RESEND_FROM_EMAIL="CashTraka <receipts@mail.example.com>"

# ─── File storage (Uploadcare) — hosts receipt PDFs + business logos ──────
# Get your public key from https://app.uploadcare.com/ → API keys. Only the
# public key is required — uploads use Uploadcare's anonymous-upload
# endpoint. Leave unset to disable uploads (receipts still render on demand,
# logo upload returns 503 instead of storing).
UPLOADCARE_PUBLIC_KEY=""
# Optional — only needed for future delete / list / signed-URL operations
# via Uploadcare's REST API. Unused by today's codebase.
UPLOADCARE_SECRET_KEY=""

# ─── Billing (Paystack) — required for paid plans + trials ────────────────
# Get keys from https://dashboard.paystack.com/#/settings/developer. Use
# pk_test_ / sk_test_ for local dev; swap to pk_live_ / sk_live_ for prod.
# Leaving these unset keeps the app working — trial start still flips plan;
# Paystack checkout routes return a friendly "Billing not configured" error.
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""
# From the Webhook URL page on Paystack. HMAC-SHA512 signing key — used to
# verify every webhook delivery. If unset, /api/billing/webhook rejects all
# requests.
PAYSTACK_WEBHOOK_SECRET=""
# Where Paystack redirects the customer after checkout. Must be publicly
# reachable in prod; in dev point to http://localhost:3000/billing/callback.
BILLING_REDIRECT_URL="http://localhost:3000/billing/callback"

# ─── Cron (Vercel Cron) — protects the rent reminder cron endpoint ───────
# Generate with: openssl rand -base64 32
# Set the same value in your vercel.json and as the CRON_SECRET env var on
# Vercel. This prevents public access to /api/cron/rent-reminders.
CRON_SECRET=""
