# CashTraka — Postgres template
#
# Production deployments should use Postgres. Steps:
#  1) In prisma/schema.prisma, change `provider = "sqlite"` to `provider = "postgresql"`.
#  2) Copy this file to `.env` and fill in real values.
#  3) Run: npx prisma migrate deploy
#  4) Seed:  npm run db:seed   (optional)

# Postgres connection string (Supabase, Neon, Railway, local, etc.)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cashtraka?schema=public"

# Generate with: openssl rand -base64 32
AUTH_SECRET=""

APP_URL="https://app.cashtraka.app"

# ─── Email (Resend) ───────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="CashTraka <receipts@mail.cashtraka.app>"

# ─── File storage (Cloudinary) ────────────────────────────────────────────
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
