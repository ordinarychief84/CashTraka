// CashTraka — WhatsApp Sales & Cash Tracker + Property Manager
// Prisma schema. Provider is sqlite for easy local dev; swap to postgresql for prod.
// To deploy against Postgres:
//   1) Change `provider = "sqlite"` to `provider = "postgresql"` below.
//   2) Set DATABASE_URL to your Postgres connection string (see .env.postgres.example).
//   3) Run `npx prisma migrate deploy` (or `prisma migrate dev --name whatever` in dev).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- USER ----------

model User {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  passwordHash         String
  businessName         String?
  whatsappNumber       String?
  receiptFooter        String?
  /// "seller" (default) or "property_manager"
  businessType         String    @default("seller")
  /// "free" | "business" | "business_plus" | "landlord" | "estate_manager"
  plan                 String    @default("free")
  /// "USER" (default) or "ADMIN". Admins access /admin.
  role                 String    @default("USER")
  /// Suspended users cannot log in.
  isSuspended          Boolean   @default(false)
  /// Timestamp of last successful login (for audit + analytics).
  lastLoginAt          DateTime?

  bankName             String?
  bankAccountNumber    String?
  bankAccountName      String?

  /// Address line shown on invoices.
  businessAddress      String?
  /// URL of the seller's logo (uploaded via Cloudinary) — printed on receipts & invoices.
  logoUrl              String?

  /// Billing state. `plan` (above) is the *tier name*; these fields describe
  /// the subscription lifecycle around that tier.
  /// "free" | "trialing" | "active" | "past_due" | "cancelled"
  subscriptionStatus       String    @default("free")
  /// End of the 14-day trial, if we started one. null if never trialled.
  trialEndsAt              DateTime?
  /// End of the current paid period (renewal date, or cancelled-grace boundary).
  currentPeriodEnd         DateTime?
  /// Paystack identifiers (stored once on first successful charge).
  paystackCustomerCode     String?
  paystackSubscriptionCode String?
  /// The plan the user picked at checkout; cleared when the webhook confirms.
  pendingPlan              String?

  /// Personal-expense thresholds (naira). When the owner's personal spending
  /// in the current week / month crosses either number, the dashboard
  /// surfaces a warning banner. Both are optional — leave null to disable.
  personalBudgetWeekly     Int?
  personalBudgetMonthly    Int?

  onboardingCompleted  Boolean   @default(false)
  /// Whether the user has verified their email via OTP.
  emailVerified        Boolean   @default(false)
  /// Timestamp when user accepted Terms & Privacy Policy.
  termsAcceptedAt      DateTime?
  /// Timestamp when the delayed welcome email was sent (30 min after signup).
  welcomeEmailSentAt   DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  customers            Customer[]
  payments             Payment[]
  debts                Debt[]
  products             Product[]
  expenses             Expense[]
  templates            MessageTemplate[]
  fraudReports         FraudReport[]
  invoices             Invoice[]
  reminderSchedules    ReminderSchedule[]
  properties           Property[]
  tenants              Tenant[]
  rentPayments         RentPayment[]
  staffMembers         StaffMember[]
  attendance           Attendance[]
  staffPayments        StaffPayment[]
  tasks                Task[]
  checklists           Checklist[]
  checklistRuns        ChecklistRun[]
  receipts             Receipt[]
  adminNotesAuthored   AdminNote[]       @relation("AdminNoteAuthor")
  adminNotesReceived   AdminNote[]       @relation("AdminNoteTarget")
  paymentAttempts      PaymentAttempt[]
  passwordResetTokens  PasswordResetToken[]
  leaseReminders       LeaseReminder[]
  supportTickets       SupportTicket[]   @relation("UserTickets")
  assignedTickets      SupportTicket[]   @relation("AssignedTickets")
  ticketReplies        TicketReply[]
  notifications        Notification[]
  refunds              Refund[]          @relation("UserRefunds")
  processedRefunds     Refund[]          @relation("ProcessedRefunds")
  auditLogs            AuditLog[]        @relation("AuditLogAdmin")
  paymentRequests      PaymentRequest[]
  emailVerifications   EmailVerification[]

  @@index([role])
  @@index([businessType])
  @@index([isSuspended])
  @@index([lastLoginAt])
}

// ---------- CORE: customers, payments, debts ----------

model Customer {
  id               String    @id @default(cuid())
  userId           String
  name             String
  phone            String
  totalPaid        Int       @default(0)
  totalOwed        Int       @default(0)
  transactionCount Int       @default(0)
  lastActivityAt   DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments         Payment[]
  debts            Debt[]
  invoices         Invoice[]
  paymentRequests  PaymentRequest[]

  @@unique([userId, phone])
  @@index([userId])
  @@index([phone])
}

model Payment {
  id                   String    @id @default(cuid())
  userId               String
  customerId           String
  customerNameSnapshot String
  phoneSnapshot        String
  amount               Int
  status               String    @default("PAID")
  createdAt            DateTime  @default(now())

  referenceCode        String?   @unique
  verified             Boolean   @default(false)
  verifiedAt           DateTime?
  verificationMethod   String?
  bankAlertText        String?
  bankAlertSenderName  String?
  bankAlertBank        String?
  claimedAt            DateTime?

  /// If this payment was created from an invoice, link back.
  invoiceId            String?

  /// Whether a receipt was auto-sent after verification.
  receiptSentAt        DateTime?

  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer             Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items                PaymentItem[]
  invoice              Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, verified])
}

model PaymentItem {
  id          String   @id @default(cuid())
  paymentId   String
  productId   String?
  description String
  unitPrice   Int
  quantity    Int      @default(1)

  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([paymentId])
}

model Debt {
  id                   String    @id @default(cuid())
  userId               String
  customerId           String
  customerNameSnapshot String
  phoneSnapshot        String
  amountOwed           Int
  amountPaid           Int       @default(0)
  dueDate              DateTime?
  status               String    @default("OPEN")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer             Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reminderSchedules    ReminderSchedule[]

  @@index([userId, status])
}

// ---------- PRODUCTS ----------

model Product {
  id          String    @id @default(cuid())
  userId      String
  name        String
  price       Int
  cost        Int?
  stock       Int       @default(0)
  trackStock  Boolean   @default(true)
  lowStockAt  Int       @default(3)
  note        String?
  archived    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       PaymentItem[]
  invoiceItems InvoiceItem[]

  @@index([userId, archived])
}

// ---------- EXPENSES ----------

model Expense {
  id             String   @id @default(cuid())
  userId         String
  amount         Int
  category       String
  note           String?
  /// "business" (default) or "personal"
  kind           String   @default("business")
  /// Payment method: cash, transfer, card, pos, other
  paymentMethod  String?
  /// Vendor / payee name
  vendor         String?
  /// Whether this is a recurring expense
  isRecurring    Boolean  @default(false)
  /// Receipt or reference number
  receiptRef     String?
  /// Whether this expense is tax-deductible (business only)
  taxDeductible  Boolean  @default(false)
  incurredOn     DateTime @default(now())
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, incurredOn])
  @@index([userId, kind, incurredOn])
}

// ---------- MESSAGING ----------

model MessageTemplate {
  id          String   @id @default(cuid())
  userId      String
  name        String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- FRAUD ----------

model FraudReport {
  id         String   @id @default(cuid())
  userId     String
  phone      String
  reason     String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phone])
  @@index([phone])
}

// ---------- INVOICES ----------

/// A formal invoice the seller can generate and share before or after payment.
/// Public at /invoice/[invoiceNumber].
model Invoice {
  id              String    @id @default(cuid())
  userId          String
  customerId      String?
  /// Human-readable number like "INV-00042".
  invoiceNumber   String    @unique
  customerName    String
  customerPhone   String
  customerEmail   String?
  /// "DRAFT" | "SENT" | "PAID" | "CANCELLED"
  status          String    @default("DRAFT")
  subtotal        Int       @default(0)
  tax             Int       @default(0)
  total           Int       @default(0)
  note            String?
  dueDate         DateTime?
  issuedAt        DateTime  @default(now())
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items           InvoiceItem[]
  payments        Payment[]

  @@index([userId, status])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String?
  description String
  unitPrice   Int
  quantity    Int      @default(1)

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
}

// ---------- REMINDERS ----------

/// A scheduled reminder linked to a Debt. The system surfaces which reminders are
/// "due today" so the seller can one-tap send them all in WhatsApp.
model ReminderSchedule {
  id          String    @id @default(cuid())
  userId      String
  debtId      String
  /// "daily" | "every_3_days" | "weekly" | "custom"
  frequency   String    @default("weekly")
  /// Custom: number of days between reminders. Used when frequency=custom.
  intervalDays Int      @default(7)
  nextDueAt   DateTime
  lastSentAt  DateTime?
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  debt        Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([userId, nextDueAt])
}

// ---------- PROPERTY MANAGEMENT ----------

/// A property (building / compound) owned or managed by the user.
model Property {
  id            String    @id @default(cuid())
  userId        String
  name          String
  address       String?
  unitCount     Int       @default(0)
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenants       Tenant[]

  @@index([userId])
}

/// A tenant occupying a unit in a Property.
model Tenant {
  id            String    @id @default(cuid())
  userId        String
  propertyId    String
  name          String
  phone         String
  unitLabel     String?
  /// Monthly rent in Naira.
  rentAmount    Int
  /// Day of month rent is due (1-28).
  rentDueDay    Int       @default(1)
  /// "monthly" | "quarterly" | "yearly"
  rentFrequency String    @default("monthly")
  leaseStart    DateTime?
  leaseEnd      DateTime?
  /// "active" | "moved_out" | "evicted"
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  rentPayments    RentPayment[]
  leaseReminders  LeaseReminder[]

  @@index([userId, status])
}

/// Tracks each rent payment (or partial) for a tenant in a given period.
model RentPayment {
  id           String    @id @default(cuid())
  userId       String
  tenantId     String
  amount       Int
  /// The calendar month this covers, e.g. "2026-04".
  period       String
  /// "PAID" | "PARTIAL" | "PENDING" | "OVERDUE"
  status       String    @default("PENDING")
  verified     Boolean   @default(false)
  paidAt       DateTime?
  note         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, period])
  @@index([userId, period])
}


/// Tracks lease-lifecycle reminders so the cron never double-sends.
/// One row per (tenant x reminder type). Created lazily by the cron route.
model LeaseReminder {
  id         String    @id @default(cuid())
  userId     String
  tenantId   String
  /// "30_day_warning" | "expiry_day" | "post_expiry" | "notice_to_quit"
  kind       String
  sentAt     DateTime  @default(now())
  /// "email" | "whatsapp" | "both"
  channel    String    @default("email")

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, kind])
  @@index([userId])
}

// ---------- TEAM, ATTENDANCE & PAYROLL ----------

model StaffMember {
  id          String    @id @default(cuid())
  userId      String
  name        String
  phone       String?
  pin         String?
  role        String?
  email                String?
  passwordHash         String?
  accessRole           String    @default("NONE")
  inviteToken          String?   @unique
  inviteExpiresAt      DateTime?
  lastLoginAt          DateTime?
  payType     String    @default("monthly")
  payAmount   Int       @default(0)
  startDate   DateTime?
  bankName             String?
  bankAccountNumber    String?
  bankAccountName      String?
  nextOfKinName        String?
  nextOfKinPhone       String?
  notes       String?
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendance    Attendance[]
  staffPayments StaffPayment[]
  tasks         Task[]

  @@unique([userId, email])
  @@index([userId, status])
  @@index([email])
}

model Attendance {
  id        String   @id @default(cuid())
  userId    String
  staffId   String
  date      DateTime
  status    String   @default("present")
  note      String?
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([userId, date])
}

model StaffPayment {
  id           String    @id @default(cuid())
  userId       String
  staffId      String
  kind         String
  amount       Int
  periodStart  DateTime?
  periodEnd    DateTime?
  note         String?
  paidAt       DateTime  @default(now())
  createdAt    DateTime  @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([userId, paidAt])
  @@index([staffId, paidAt])
}

// ---------- TASK MANAGEMENT ----------

model Task {
  id           String    @id @default(cuid())
  userId       String
  title        String
  description  String?
  assignedToId String?
  customerId   String?
  priority     String    @default("normal")
  status       String    @default("todo")
  dueDate      DateTime?
  completedAt  DateTime?
  completedByKind String?
  completedById   String?
  completionNote  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTo   StaffMember? @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([assignedToId, status])
}

// ---------- CHECKLISTS ----------

model Checklist {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  category    String    @default("custom")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       ChecklistItem[]
  runs        ChecklistRun[]

  @@index([userId])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String
  label       String
  sortOrder   Int       @default(0)

  checklist   Checklist        @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  results     ChecklistResult[]

  @@index([checklistId])
}

model ChecklistRun {
  id          String    @id @default(cuid())
  userId      String
  checklistId String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  completedBy String?
  createdAt   DateTime  @default(now())

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklist   Checklist         @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  results     ChecklistResult[]

  @@index([userId, checklistId])
}

model ChecklistResult {
  id        String    @id @default(cuid())
  runId     String
  itemId    String
  checked   Boolean   @default(false)
  note      String?
  checkedAt DateTime?

  run       ChecklistRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  item      ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([runId])
}

// ---------- RECEIPTS ----------

model Receipt {
  id             String    @id @default(cuid())
  userId         String
  customerId     String?
  paymentId      String?   @unique
  debtId         String?   @unique
  receiptNumber  String    @unique
  pdfUrl         String?
  status         String    @default("GENERATED")
  emailedTo      String?
  emailedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}

// ---------- ADMIN ----------

model AdminNote {
  id            String   @id @default(cuid())
  adminUserId   String
  targetUserId  String
  note          String
  createdAt     DateTime @default(now())

  author        User     @relation("AdminNoteAuthor", fields: [adminUserId],  references: [id], onDelete: Cascade)
  target        User     @relation("AdminNoteTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([targetUserId, createdAt])
}

model SystemSetting {
  id         String   @id @default(cuid())
  key        String   @unique
  value      String
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

// ---------- BILLING ----------

model PaymentAttempt {
  id                String   @id @default(cuid())
  userId            String
  targetPlan        String
  amount            Int
  currency          String   @default("NGN")
  paystackReference String   @unique
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refunds Refund[]

  @@index([userId, createdAt])
  @@index([status])
}

model BillingEvent {
  id              String   @id @default(cuid())
  paystackEventId String   @unique
  eventType       String
  payloadJson     String
  processedAt     DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

// ---------- SUPPORT & TICKETS ----------

model SupportTicket {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  description String
  status      String   @default("open")
  priority    String   @default("medium")
  assignedTo  String?
  closedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation("UserTickets", fields: [userId], references: [id], onDelete: Cascade)
  assignee    User?    @relation("AssignedTickets", fields: [assignedTo], references: [id], onDelete: SetNull)
  replies     TicketReply[]

  @@index([userId, createdAt])
  @@index([status])
  @@index([assignedTo])
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  message   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

// ---------- NOTIFICATIONS ----------

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("info")
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

// ---------- REFUNDS ----------

model Refund {
  id                String   @id @default(cuid())
  userId            String
  paymentAttemptId  String?
  amount            Int
  currency          String   @default("NGN")
  status            String   @default("pending")
  reason            String
  adminNote         String?
  processedBy       String?
  processedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation("UserRefunds", fields: [userId], references: [id], onDelete: Cascade)
  processor         User?    @relation("ProcessedRefunds", fields: [processedBy], references: [id], onDelete: SetNull)
  paymentAttempt    PaymentAttempt? @relation(fields: [paymentAttemptId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status])
}

// ---------- AUDIT LOGGING ----------

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  targetId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  admin     User     @relation("AuditLogAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([action])
  @@index([targetId])
}

// ---------- PAYLINK (Payment Requests) ----------

model PaymentRequest {
  id               String    @id @default(cuid())
  userId           String
  customerId       String?
  token            String    @unique @default(cuid())
  linkNumber       String    @unique
  customerName     String
  customerPhone    String
  amount           Int
  description      String?
  status           String    @default("pending")
  viewedAt         DateTime?
  claimedAt        DateTime?
  confirmedAt      DateTime?
  whatsappSentAt   DateTime?
  debtId           String?
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer         Customer? @relation(fields: [customerId], referenc