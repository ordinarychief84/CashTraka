// CashTraka — WhatsApp Sales & Cash Tracker + Property Manager
// Prisma schema. Provider is sqlite for easy local dev; swap to postgresql for prod.
// To deploy against Postgres:
//   1) Change `provider = "sqlite"` to `provider = "postgresql"` below.
//   2) Set DATABASE_URL to your Postgres connection string (see .env.postgres.example).
//   3) Run `npx prisma migrate deploy` (or `prisma migrate dev --name whatever` in dev).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- USER ----------

model User {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  passwordHash         String
  businessName         String?
  whatsappNumber       String?
  receiptFooter        String?
  /// "seller" (default) or "property_manager"
  businessType         String    @default("seller")
  /// "free" | "business" | "business_plus" | "landlord" | "estate_manager"
  plan                 String    @default("free")
  /// "USER" (default) or "ADMIN". Admins access /admin.
  role                 String    @default("USER")
  /// Suspended users cannot log in.
  isSuspended          Boolean   @default(false)
  /// Timestamp of last successful login (for audit + analytics).
  lastLoginAt          DateTime?

  bankName             String?
  bankAccountNumber    String?
  bankAccountName      String?

  /// Address line shown on invoices.
  businessAddress      String?
  /// URL of the seller's logo (uploaded via Cloudinary) — printed on receipts & invoices.
  logoUrl              String?

  /// Per-business receipt prefix. Defaults to "CT" → CT-00001. Editable in Settings.
  receiptPrefix        String?   @default("CT")

  /// Public storefront slug (used in /store/[slug]). Unique, kebab-case.
  slug                 String?   @unique
  /// Whether the public catalog is published. Slug must also be set.
  catalogEnabled       Boolean   @default(false)
  /// Optional headline shown above the catalog grid.
  catalogTagline       String?

  /// ── Nigerian tax / FIRS compliance ────────────────────────────
  /// Tax Identification Number issued by FIRS. Required on tax invoices
  /// once the business is VAT-registered.
  tin                  String?
  /// Whether the business is VAT-registered with FIRS. Mandatory for
  /// businesses with annual turnover > ₦25M; optional below that threshold.
  vatRegistered        Boolean   @default(false)
  /// Default VAT rate (percent) applied when vatRegistered=true. Standard
  /// Nigerian rate is 7.5; some categories may use a different rate.
  vatRate              Float     @default(7.5)
  /// Merchant ID assigned by FIRS once the business onboards to MBS.
  /// Required by the real FIRS adapter; not used by NoopFIRSAdapter.
  firsMerchantId       String?

  /// Billing state. `plan` (above) is the *tier name*; these fields describe
  /// the subscription lifecycle around that tier.
  /// "free" | "trialing" | "active" | "past_due" | "cancelled"
  subscriptionStatus       String    @default("free")
  /// End of the 14-day trial, if we started one. null if never trialled.
  trialEndsAt              DateTime?
  /// End of the current paid period (renewal date, or cancelled-grace boundary).
  currentPeriodEnd         DateTime?
  /// Paystack identifiers (stored once on first successful charge).
  paystackCustomerCode     String?
  paystackSubscriptionCode String?
  /// The plan the user picked at checkout; cleared when the webhook confirms.
  pendingPlan              String?

  /// Personal-expense thresholds (naira). When the owner's personal spending
  /// in the current week / month crosses either number, the dashboard
  /// surfaces a warning banner. Both are optional — leave null to disable.
  personalBudgetWeekly     Int?
  personalBudgetMonthly    Int?

  onboardingCompleted  Boolean   @default(false)
  /// Whether the user has verified their email via OTP.
  emailVerified        Boolean   @default(false)
  /// Timestamp when user accepted Terms & Privacy Policy.
  termsAcceptedAt      DateTime?
  /// Timestamp when the delayed welcome email was sent (30 min after signup).
  welcomeEmailSentAt   DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  customers            Customer[]
  payments             Payment[]
  debts                Debt[]
  products             Product[]
  expenses             Expense[]
  templates            MessageTemplate[]
  fraudReports         FraudReport[]
  invoices             Invoice[]
  reminderSchedules    ReminderSchedule[]
  properties           Property[]
  tenants              Tenant[]
  rentPayments         RentPayment[]
  customRoles          CustomRole[]
  staffMembers         StaffMember[]
  attendance           Attendance[]
  staffPayments        StaffPayment[]
  tasks                Task[]
  checklists           Checklist[]
  checklistRuns        ChecklistRun[]
  sales                Sale[]
  receipts             Receipt[]
  adminNotesAuthored   AdminNote[]       @relation("AdminNoteAuthor")
  adminNotesReceived   AdminNote[]       @relation("AdminNoteTarget")
  paymentAttempts      PaymentAttempt[]
  passwordResetTokens  PasswordResetToken[]
  leaseReminders       LeaseReminder[]
  supportTickets       SupportTicket[]   @relation("UserTickets")
  assignedTickets      SupportTicket[]   @relation("AssignedTickets")
  ticketReplies        TicketReply[]
  notifications        Notification[]
  refunds              Refund[]          @relation("UserRefunds")
  processedRefunds     Refund[]          @relation("ProcessedRefunds")
  auditLogs            AuditLog[]        @relation("AuditLogAdmin")
  paymentRequests      PaymentRequest[]
  emailVerifications   EmailVerification[]
  reminderRules        ReminderRule[]
  reminderLogs         ReminderLog[]
  customerNotes        CustomerNote[]
  createdAdminStaff    AdminStaff[]      @relation("AdminStaffCreator")
  promisesToPay        PromiseToPay[]
  installmentPlans     InstallmentPlan[]
  catalogEvents        CatalogEvent[]
  albums               Album[]

  @@index([role])
  @@index([businessType])
  @@index([isSuspended])
  @@index([lastLoginAt])
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- CORE: customers, payments, debts ----------

model Customer {
  id               String    @id @default(cuid())
  userId           String
  name             String
  phone            String
  totalPaid        Int       @default(0)
  totalOwed        Int       @default(0)
  transactionCount Int       @default(0)
  lastActivityAt   DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  /// Phase 4 — behavior tagging: FAST_PAYER | LATE_PAYER | DORMANT | HIGH_VALUE | NEW
  behaviorTag      String?
  /// Average number of days to pay after receiving a request
  avgPayDays       Float?
  /// Number of times this customer has been reminded
  totalReminders   Int       @default(0)
  /// Last time a reminder was sent for any debt
  lastRemindedAt   DateTime?

  /// Free-text notes about this customer (e.g. preferences, history)
  notes            String?
  /// Comma-separated custom tags for grouping/filtering
  tags             String?

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments         Payment[]
  debts            Debt[]
  invoices         Invoice[]
  paymentRequests  PaymentRequest[]
  customerNotes    CustomerNote[]
  promisesToPay    PromiseToPay[]

  @@unique([userId, phone])
  @@index([userId])
  @@index([phone])
  @@index([userId, behaviorTag])
}

model CustomerNote {
  id          String   @id @default(cuid())
  customerId  String
  userId      String
  note        String
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([userId])
}

model Payment {
  id                   String    @id @default(cuid())
  userId               String
  customerId           String
  customerNameSnapshot String
  phoneSnapshot        String
  amount               Int
  status               String    @default("PAID")
  createdAt            DateTime  @default(now())

  referenceCode        String?   @unique
  verified             Boolean   @default(false)
  verifiedAt           DateTime?
  verificationMethod   String?
  bankAlertText        String?
  bankAlertSenderName  String?
  bankAlertBank        String?
  claimedAt            DateTime?

  /// If this payment was created from an invoice, link back.
  invoiceId            String?

  /// Whether a receipt was auto-sent after verification.
  receiptSentAt        DateTime?

  /// Provider payment fields (for auto-confirmed payments via webhook)
  externalRef              String?
  provider                 String?
  providerTransactionId    String?
  confirmedAutomatically   Boolean   @default(false)
  confirmedAt              DateTime?

  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer             Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items                PaymentItem[]
  invoice              Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, verified])
}

model PaymentItem {
  id          String   @id @default(cuid())
  paymentId   String
  productId   String?
  description String
  unitPrice   Int
  quantity    Int      @default(1)

  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([paymentId])
}

model Debt {
  id                   String    @id @default(cuid())
  userId               String
  customerId           String
  customerNameSnapshot String
  phoneSnapshot        String
  amountOwed           Int
  amountPaid           Int       @default(0)
  dueDate              DateTime?
  status               String    @default("OPEN")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  /// Phase 2 — follow-up tracking
  reminderCount        Int       @default(0)
  lastRemindedAt       DateTime?

  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer             Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reminderSchedules    ReminderSchedule[]
  reminderRules        ReminderRule[]

  @@index([userId, status])
}

// ---------- PRODUCTS ----------

model Product {
  id          String    @id @default(cuid())
  userId      String
  name        String
  price       Int
  cost        Int?
  stock       Int       @default(0)
  trackStock  Boolean   @default(true)
  lowStockAt  Int       @default(3)
  note        String?
  archived    Boolean   @default(false)

  /// Catalog (Sell) fields.
  /// Up to 8 Uploadcare image URLs (validator enforces the cap).
  images        String[]  @default([])
  /// Optional SKU shown on the catalog detail page.
  sku           String?
  /// Public-facing description shown on /store/[slug]/[productId].
  description   String?
  /// When true, the product appears on /store/[slug] (requires User.catalogEnabled too).
  isPublished   Boolean   @default(false)
  /// "AVAILABLE" | "LOW_STOCK" | "SOLD_OUT" — manual override used only when trackStock=false.
  catalogStatus String    @default("AVAILABLE")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         PaymentItem[]
  invoiceItems  InvoiceItem[]
  saleItems     SaleItem[]
  catalogEvents CatalogEvent[]
  albumLinks    AlbumProduct[]

  @@index([userId, archived])
  @@index([userId, isPublished])
}

// ---------- SALES (Walk-in POS) ----------

model Sale {
  id              String     @id @default(cuid())
  userId          String
  /// Auto-incrementing receipt number like "SLE-00042"
  saleNumber      String     @unique
  customerName    String?
  customerPhone   String?
  customerEmail   String?
  subtotal        Int        @default(0)
  tax             Int        @default(0)
  discount        Int        @default(0)
  total           Int        @default(0)
  /// "CASH" | "TRANSFER" | "POS" | "CARD"
  paymentMethod   String     @default("CASH")
  note            String?
  /// Exact time the sale was recorded
  soldAt          DateTime   @default(now())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           SaleItem[]

  @@index([userId, soldAt])
}

model SaleItem {
  id          String   @id @default(cuid())
  saleId      String
  productId   String?
  description String
  unitPrice   Int
  quantity    Int      @default(1)
  total       Int      @default(0)

  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([saleId])
}

// ---------- EXPENSES ----------

model Expense {
  id             String   @id @default(cuid())
  userId         String
  amount         Int
  category       String
  note           String?
  /// "business" (default) or "personal"
  kind           String   @default("business")
  /// Payment method: cash, transfer, card, pos, other
  paymentMethod  String?
  /// Vendor / payee name
  vendor         String?
  /// Whether this is a recurring expense
  isRecurring    Boolean  @default(false)
  /// Receipt or reference number
  receiptRef     String?
  /// Whether this expense is tax-deductible (business only)
  taxDeductible  Boolean  @default(false)
  incurredOn     DateTime @default(now())
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, incurredOn])
  @@index([userId, kind, incurredOn])
}

// ---------- MESSAGING ----------

model MessageTemplate {
  id          String   @id @default(cuid())
  userId      String
  name        String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- FRAUD ----------

model FraudReport {
  id         String   @id @default(cuid())
  userId     String
  phone      String
  reason     String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phone])
  @@index([phone])
}

// ---------- INVOICES ----------

/// A formal invoice the seller can generate and share before or after payment.
/// Public at /invoice/[invoiceNumber].
model Invoice {
  id              String    @id @default(cuid())
  userId          String
  customerId      String?
  /// Human-readable number like "INV-00042".
  invoiceNumber   String    @unique
  customerName    String
  customerPhone   String
  customerEmail   String?
  /// "DRAFT" | "SENT" | "PAID" | "CANCELLED"
  status          String    @default("DRAFT")
  subtotal        Int       @default(0)
  tax             Int       @default(0)
  total           Int       @default(0)
  note            String?
  dueDate         DateTime?
  issuedAt        DateTime  @default(now())
  paidAt          DateTime?

  /// 1:1 link back to the Payment that spawned this invoice (if generated from one).
  /// Used for idempotent generation from /api/payments/[id]/invoice.
  paymentId       String?   @unique

  /// ── Nigerian tax compliance fields ─────────────────────────────
  /// Buyer's TIN (required on B2B tax invoices when issuing under FIRS rules).
  buyerTin        String?
  /// Buyer's billing address.
  buyerAddress    String?
  /// Was VAT applied to this invoice? Snapshot at issue time.
  vatApplied      Boolean   @default(false)
  /// VAT rate (percent) at issue time. Snapshot from User.vatRate.
  vatRate         Float     @default(0)
  /// Currency code. Defaults to NGN. ISO-4217.
  currency        String    @default("NGN")

  /// ── FIRS MBS (Merchant Buyer Solution) submission state ────────
  /// Adapter is a Noop until FIRS_API_BASE_URL + FIRS_API_KEY are configured
  /// (see firs-invoice.service.ts).
  firsTransmissionRef String?
  /// Invoice Reference Number issued by FIRS on successful submission.
  /// Must be rendered on the invoice once received.
  firsIrn         String?
  /// Opaque QR code payload returned by FIRS. Rendered as a QR on the invoice.
  firsQrPayload   String?
  /// "PENDING" | "SUBMITTED" | "ACCEPTED" | "REJECTED" | "RETRYING" | "FAILED" | null
  firsStatus      String?
  firsLastError   String?
  firsRetryCount  Int       @default(0)
  firsSubmittedAt DateTime?
  firsAcceptedAt  DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items           InvoiceItem[]
  payments        Payment[]

  @@index([userId, status])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String?
  description String
  unitPrice   Int
  quantity    Int      @default(1)

  /// "GOODS" | "SERVICE". Required for FIRS classification.
  itemType    String   @default("GOODS")
  /// Harmonized System code (e.g., "8517.12"). Required for goods on tax invoices.
  hsCode      String?
  /// Whether this line is VAT-exempt (basic food, books, medical, etc.).
  vatExempt   Boolean  @default(false)

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
}

// ---------- REMINDERS ----------

/// A scheduled reminder linked to a Debt. The system surfaces which reminders are
/// "due today" so the seller can one-tap send them all in WhatsApp.
model ReminderSchedule {
  id          String    @id @default(cuid())
  userId      String
  debtId      String
  /// "daily" | "every_3_days" | "weekly" | "custom"
  frequency   String    @default("weekly")
  /// Custom: number of days between reminders. Used when frequency=custom.
  intervalDays Int      @default(7)
  nextDueAt   DateTime
  lastSentAt  DateTime?
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  debt        Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([userId, nextDueAt])
}

// ---------- PROPERTY MANAGEMENT ----------

/// A property (building / compound) owned or managed by the user.
model Property {
  id            String    @id @default(cuid())
  userId        String
  name          String
  address       String?
  unitCount     Int       @default(0)
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenants       Tenant[]

  @@index([userId])
}

/// A tenant occupying a unit in a Property.
model Tenant {
  id            String    @id @default(cuid())
  userId        String
  propertyId    String
  name          String
  phone         String
  unitLabel     String?
  /// Monthly rent in Naira.
  rentAmount    Int
  /// Day of month rent is due (1-28).
  rentDueDay    Int       @default(1)
  /// "monthly" | "quarterly" | "yearly"
  rentFrequency String    @default("monthly")
  leaseStart    DateTime?
  leaseEnd      DateTime?
  /// "active" | "moved_out" | "evicted"
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  rentPayments    RentPayment[]
  leaseReminders  LeaseReminder[]

  @@index([userId, status])
}

/// Tracks each rent payment (or partial) for a tenant in a given period.
model RentPayment {
  id           String    @id @default(cuid())
  userId       String
  tenantId     String
  amount       Int
  /// The calendar month this covers, e.g. "2026-04".
  period       String
  /// "PAID" | "PARTIAL" | "PENDING" | "OVERDUE"
  status       String    @default("PENDING")
  verified     Boolean   @default(false)
  paidAt       DateTime?
  note         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, period])
  @@index([userId, period])
}


/// Tracks lease-lifecycle reminders so the cron never double-sends.
/// One row per (tenant x reminder type). Created lazily by the cron route.
model LeaseReminder {
  id         String    @id @default(cuid())
  userId     String
  tenantId   String
  /// "30_day_warning" | "expiry_day" | "post_expiry" | "notice_to_quit"
  kind       String
  sentAt     DateTime  @default(now())
  /// "email" | "whatsapp" | "both"
  channel    String    @default("email")

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, kind])
  @@index([userId])
}

// ---------- TEAM, ATTENDANCE & PAYROLL ----------

model CustomRole {
  id              String    @id @default(cuid())
  userId          String
  name            String
  description     String?
  baseRole        String    @default("CASHIER")
  color           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  staffMembers    StaffMember[]

  @@unique([userId, name])
  @@index([userId])
}

model StaffMember {
  id          String    @id @default(cuid())
  userId      String
  name        String
  phone       String?
  pin         String?
  role        String?
  customRoleId         String?
  email                String?
  passwordHash         String?
  accessRole           String    @default("NONE")
  inviteToken          String?   @unique
  inviteExpiresAt      DateTime?
  lastLoginAt          DateTime?
  payType     String    @default("monthly")
  payAmount   Int       @default(0)
  startDate   DateTime?
  bankName             String?
  bankAccountNumber    String?
  bankAccountName      String?
  nextOfKinName        String?
  nextOfKinPhone       String?
  notes       String?
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  customRole    CustomRole?    @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  attendance    Attendance[]
  staffPayments StaffPayment[]
  tasks         Task[]

  @@unique([userId, email])
  @@index([userId, status])
  @@index([email])
  @@index([customRoleId])
}

model Attendance {
  id        String   @id @default(cuid())
  userId    String
  staffId   String
  date      DateTime
  status    String   @default("present")
  note      String?
  createdAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([userId, date])
}

model StaffPayment {
  id           String    @id @default(cuid())
  userId       String
  staffId      String
  kind         String
  amount       Int
  periodStart  DateTime?
  periodEnd    DateTime?
  note         String?
  paidAt       DateTime  @default(now())
  createdAt    DateTime  @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([userId, paidAt])
  @@index([staffId, paidAt])
}

// ---------- TASK MANAGEMENT ----------

model Task {
  id           String    @id @default(cuid())
  userId       String
  title        String
  description  String?
  assignedToId String?
  customerId   String?
  priority     String    @default("normal")
  status       String    @default("todo")
  dueDate      DateTime?
  completedAt  DateTime?
  completedByKind String?
  completedById   String?
  completionNote  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTo   StaffMember? @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([assignedToId, status])
}

// ---------- CHECKLISTS ----------

model Checklist {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  category    String    @default("custom")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       ChecklistItem[]
  runs        ChecklistRun[]

  @@index([userId])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String
  label       String
  sortOrder   Int       @default(0)

  checklist   Checklist        @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  results     ChecklistResult[]

  @@index([checklistId])
}

model ChecklistRun {
  id          String    @id @default(cuid())
  userId      String
  checklistId String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  completedBy String?
  createdAt   DateTime  @default(now())

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklist   Checklist         @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  results     ChecklistResult[]

  @@index([userId, checklistId])
}

model ChecklistResult {
  id        String    @id @default(cuid())
  runId     String
  itemId    String
  checked   Boolean   @default(false)
  note      String?
  checkedAt DateTime?

  run       ChecklistRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  item      ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([runId])
}

// ---------- RECEIPTS ----------

model Receipt {
  id             String    @id @default(cuid())
  userId         String
  customerId     String?
  paymentId      String?   @unique
  debtId         String?   @unique
  receiptNumber  String    @unique
  pdfUrl         String?
  status         String    @default("GENERATED")
  emailedTo      String?
  emailedAt      DateTime?

  /// Outstanding balance when this receipt was generated (partial payment).
  /// null = full payment; >0 means the receipt should display "Balance: X".
  balanceRemaining Int?
  /// Where this receipt originated. "MANUAL" | "PAYSTACK" | "PROMISE" | "INSTALLMENT" | "DEBT" | "CATALOG"
  source           String   @default("MANUAL")

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
  @@index([userId, source])
}

// ---------- ADMIN ----------

model AdminNote {
  id            String   @id @default(cuid())
  adminUserId   String
  targetUserId  String
  note          String
  createdAt     DateTime @default(now())

  author        User     @relation("AdminNoteAuthor", fields: [adminUserId],  references: [id], onDelete: Cascade)
  target        User     @relation("AdminNoteTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([targetUserId, createdAt])
}

model SystemSetting {
  id         String   @id @default(cuid())
  key        String   @unique
  value      String
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

// ---------- CATALOG (Sell) ----------

/// Public catalog activity log. Used to track WhatsApp order clicks
/// without creating Payment rows (we don't auto-pend orders — see plan).
/// ipHash is sha256(ip + YYYY-MM-DD + AUTH_SECRET): rotates daily, prevents linkability.
model CatalogEvent {
  id          String   @id @default(cuid())
  userId      String
  productId   String?
  /// "VIEW" | "WHATSAPP_ORDER"
  type        String
  ipHash      String?
  userAgent   String?
  referrer    String?
  /// Optional shopper details captured on the order form (free text, length-capped).
  customerName  String?
  customerPhone String?
  note          String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([productId])
  @@index([userId, type])
}

/// Yupoo-style product album. A grouping of catalog products that the seller
/// can share via a single link, optionally protected by a passcode that
/// they share separately (e.g. on WhatsApp).
model Album {
  id               String   @id @default(cuid())
  userId           String
  /// Per-user unique URL slug. e.g. "summer-2026" → /store/<seller>/album/summer-2026
  slug             String
  title            String
  description      String?
  /// URL of a cover image. When null, the public page falls back to the
  /// first product's first image.
  coverImageUrl    String?
  /// When true, the public album page shows a passcode prompt before the
  /// product grid. The unlock API issues a signed httpOnly cookie.
  passcodeRequired Boolean  @default(false)
  /// bcrypt hash of the passcode. null when passcodeRequired=false.
  passcodeHash     String?
  /// Whether the album is visible on /store/<slug> at all.
  isPublished      Boolean  @default(true)
  /// Display order on the storefront homepage. Lower = first.
  position         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  products         AlbumProduct[]

  @@unique([userId, slug])
  @@index([userId, isPublished])
}

/// Many-to-many join. Position lets the seller drag-reorder products inside
/// an album without affecting their order in other albums.
model AlbumProduct {
  albumId   String
  productId String
  position  Int      @default(0)
  addedAt   DateTime @default(now())

  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([albumId, productId])
  @@index([albumId, position])
  @@index([productId])
}

// ---------- BILLING ----------

model PaymentAttempt {
  id                String   @id @default(cuid())
  userId            String
  targetPlan        String
  amount            Int
  currency          String   @default("NGN")
  paystackReference String   @unique
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refunds Refund[]

  @@index([userId, createdAt])
  @@index([status])
}

model BillingEvent {
  id              String   @id @default(cuid())
  paystackEventId String   @unique
  eventType       String
  payloadJson     String
  processedAt     DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

// ---------- SUPPORT & TICKETS ----------

model SupportTicket {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  description String
  status      String   @default("open")
  priority    String   @default("medium")
  assignedTo  String?
  closedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation("UserTickets", fields: [userId], references: [id], onDelete: Cascade)
  assignee    User?    @relation("AssignedTickets", fields: [assignedTo], references: [id], onDelete: SetNull)
  replies     TicketReply[]

  @@index([userId, createdAt])
  @@index([status])
  @@index([assignedTo])
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  message   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

// ---------- NOTIFICATIONS ----------

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("info")
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

// ---------- REFUNDS ----------

model Refund {
  id                String   @id @default(cuid())
  userId            String
  paymentAttemptId  String?
  amount            Int
  currency          String   @default("NGN")
  status            String   @default("pending")
  reason            String
  adminNote         String?
  processedBy       String?
  processedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation("UserRefunds", fields: [userId], references: [id], onDelete: Cascade)
  processor         User?    @relation("ProcessedRefunds", fields: [processedBy], references: [id], onDelete: SetNull)
  paymentAttempt    PaymentAttempt? @relation(fields: [paymentAttemptId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status])
}

// ---------- AUDIT LOGGING ----------

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  targetId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  admin     User     @relation("AuditLogAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([action])
  @@index([targetId])
}

// ---------- PAYLINK (Payment Requests) ----------

model PaymentRequest {
  id               String    @id @default(cuid())
  userId           String
  customerId       String?
  token            String    @unique @default(cuid())
  linkNumber       String    @unique
  customerName     String
  customerPhone    String
  amount           Int
  description      String?
  status           String    @default("pending")
  viewedAt         DateTime?
  claimedAt        DateTime?
  confirmedAt      DateTime?
  whatsappSentAt   DateTime?
  emailSentAt      DateTime?
  customerEmail    String?
  debtId           String?
  expiresAt        DateTime?

  /// Provider payment tracking (for auto-confirmed paylinks)
  provider         String?
  externalRef      String?
  /// PENDING | SUCCESS | FAILED
  paymentStatus    String?
  webhookVerifiedAt DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer         Customer? @relation(fields: [customerId], references: [id])

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([externalRef])
}

// ---------- PHASE 2: AUTO FOLLOW-UP REMINDERS ----------

/// A rule that defines automatic reminder behavior for a specific debt.
/// The cron job (`/api/cron/run-reminders`) evaluates all active rules and
/// creates ReminderLog entries + surfaces WhatsApp deep-links.
model ReminderRule {
  id            String    @id @default(cuid())
  userId        String
  debtId        String
  /// "gentle" | "firm" | "final" — escalation tone
  tone          String    @default("gentle")
  /// Number of days between auto-reminders
  intervalDays  Int       @default(3)
  /// Maximum number of reminders before the rule auto-disables
  maxReminders  Int       @default(5)
  /// How many reminders have been sent under this rule
  sentCount     Int       @default(0)
  /// When the next reminder should fire
  nextFireAt    DateTime
  /// Whether this rule is active
  enabled       Boolean   @default(true)
  /// "whatsapp" | "email" | "both"
  channel       String    @default("whatsapp")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  debt          Debt      @relation(fields: [debtId], references: [id], onDelete: Cascade)
  logs          ReminderLog[]

  @@index([userId, enabled, nextFireAt])
  @@index([debtId])
}

/// Log of every reminder sent (for audit & analytics).
model ReminderLog {
  id            String    @id @default(cuid())
  userId        String
  ruleId        String?
  debtId        String?
  customerId    String?
  customerName  String
  customerPhone String
  amount        Int
  /// "whatsapp" | "email"
  channel       String
  /// "gentle" | "firm" | "final"
  tone          String    @default("gentle")
  /// WhatsApp deep link or email ID for tracking
  deliveryRef   String?
  createdAt     DateTime  @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  rule          ReminderRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([ruleId])
}

// ---------- PHASE 4: COLLECTION PERFORMANCE SCORE ----------

/// Snapshot of a seller's collection performance, computed daily by cron.
/// Powers the "Collection Score" widget on the dashboard.
model CollectionScore {
  id                  String    @id @default(cuid())
  userId              String
  /// 0-100 overall collection effectiveness score
  score               Int       @default(50)
  /// Percentage of debts collected on time (0-100)
  onTimeRate          Float     @default(0)
  /// Average days to collect across all debts
  avgCollectionDays   Float     @default(0)
  /// Total amount collected in the scoring window
  collectedAmount     Int       @default(0)
  /// Total amount outstanding
  outstandingAmount   Int       @default(0)
  /// Number of active follow-up rules
  activeReminders     Int       @default(0)
  /// Scoring period start
  periodStart         DateTime
  /// Scoring period end
  periodEnd           DateTime
  createdAt           DateTime  @default(now())

  @@unique([userId, periodStart])
  @@index([userId, createdAt])
}

// ---------- BLOG ----------

model BlogPost {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  excerpt       String    @default("")
  content       String
  coverImage    String?
  author        String
  status        String    @default("draft")
  category      String    @default("general")
  tags          String    @default("")
  /// SEO meta description (auto-filled from excerpt if blank)
  metaDescription String?
  /// Open Graph title override
  ogTitle       String?
  /// Open Graph image override (falls back to coverImage)
  ogImage       String?
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([category])
  @@index([slug])
}

// ---------- ADMIN STAFF (Platform RBAC) ----------

model AdminStaff {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  passwordHash    String?
  /// SUPER_ADMIN | BLOG_MANAGER | BILLING_MANAGER | SUPPORT_AGENT | PROPERTY_MANAGER | REPORTS_VIEWER
  adminRole       String
  status          String    @default("invited") // invited | active | suspended | revoked
  inviteToken     String?   @unique
  inviteExpiresAt DateTime?
  /// The admin User.id who created this staff
  createdById     String
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  createdBy       User      @relation("AdminStaffCreator", fields: [createdById], references: [id])

  @@index([adminRole])
  @@index([status])
  @@index([email])
}

// ---------- PROMISE TO PAY ----------

/// A structured payment commitment sent to a debtor. Public at /promise/[publicToken].
model PromiseToPay {
  id                   String    @id @default(cuid())
  userId               String
  customerId           String?
  debtId               String?
  paymentRequestId     String?
  customerNameSnapshot String
  phoneSnapshot        String
  originalAmount       Int
  remainingAmount      Int
  /// OPEN | PARTIALLY_PAID | PROMISED | PAID | BROKEN | CANCELLED | EXPIRED
  status               String    @default("OPEN")
  publicToken          String    @unique @default(cuid())
  publicUrl            String?
  note                 String?
  lastActionAt         DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer             Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  commitments          PromiseCommitment[]
  payments             PromisePayment[]

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([publicToken])
  @@index([customerId])
  @@index([debtId])
}

/// A commitment made by the debtor on a PromiseToPay.
model PromiseCommitment {
  id              String    @id @default(cuid())
  promiseToPayId  String
  /// PAY_NOW | PAY_PART | PAY_ON_DATE
  commitmentType  String
  committedAmount Int?
  promisedDate    DateTime?
  message         String?
  createdAt       DateTime  @default(now())

  promiseToPay    PromiseToPay @relation(fields: [promiseToPayId], references: [id], onDelete: Cascade)

  @@index([promiseToPayId])
}

/// A payment made against a PromiseToPay, tracked through a payment provider.
model PromisePayment {
  id                   String    @id @default(cuid())
  promiseToPayId       String
  /// PAYSTACK | FLUTTERWAVE
  provider             String?
  providerReference    String?
  providerTransactionId String?
  amount               Int
  /// PENDING | SUCCESS | FAILED
  status               String    @default("PENDING")
  verifiedAt           DateTime?
  paidAt               DateTime?
  rawWebhookStored     Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  promiseToPay         PromiseToPay @relation(fields: [promiseToPayId], references: [id], onDelete: Cascade)

  @@index([promiseToPayId])
  @@index([providerReference])
  @@index([providerTransactionId])
  @@index([status])
}

/// Installment plan for recurring auto-debit via Paystack authorization.
model InstallmentPlan {
  id                             String    @id @default(cuid())
  userId                         String
  promiseToPayId                 String?
  debtId                         String?
  customerId                     String?
  customerNameSnapshot           String
  phoneSnapshot                  String
  totalAmount                    Int
  remainingAmount                Int
  initialAmount                  Int?      // first payment amount (may differ from recurring)
  recurringAmount                Int
  /// DAILY | WEEKLY | BIWEEKLY | MONTHLY
  interval                       String    @default("MONTHLY")
  totalInstallments              Int?      // null = charge until cleared
  completedInstallments          Int       @default(0)
  nextChargeAt                   DateTime?
  lastChargedAt                  DateTime?
  /// ACTIVE | COMPLETED | FAILED | CANCELLED | PAUSED
  status                         String    @default("ACTIVE")
  paystackAuthorizationCode      String?
  paystackAuthorizationReusable  Boolean   @default(false)
  paystackCustomerCode           String?
  paystackEmail                  String?
  failedAttempts                 Int       @default(0)
  lastFailureReason              String?
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt

  user                           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  charges                        InstallmentCharge[]

  @@index([userId, status])
  @@index([status, nextChargeAt])
  @@index([promiseToPayId])
  @@index([debtId])
  @@index([customerId])
}

/// Individual charge attempt within an installment plan.
model InstallmentCharge {
  id                    String    @id @default(cuid())
  installmentPlanId     String
  userId                String
  amount                Int
  reference             String    @unique
  /// PENDING | SUCCESS | FAILED | VERIFICATION_PENDING
  status                String    @default("PENDING")
  providerTransactionId String?
  failureReason         String?
  paymentId             String?   // linked Payment record after success
  receiptId             String?   // linked Receipt record after success
  verifiedAt            DateTime?
  paidAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  installmentPlan       InstallmentPlan @relation(fields: [installmentPlanId], references: [id], onDelete: Cascade)

  @@index([installmentPlanId])
  @@index([reference])
  @@index([providerTransactionId])
  @@index([status])
  @@index([createdAt])
}

/// Durable log for all incoming payment webhooks — audit and replay.
model WebhookEventLog {
  id                  String    @id @default(cuid())
  /// PAYSTACK | FLUTTERWAVE
  provider            String
  eventType           String
  reference           String?
  transactionId       String?
  payload             String
  /// RECEIVED | VERIFIED | REJECTED | DUPLICATE | FAILED
  verificationStatus  String    @default("RECEIVED")
  processedAt         DateTime?
  createdAt           DateTime  @default(now())

  @@index([provider, reference])
  @@index([provider, transactionId])
  @@index([verificationStatus])
  @@index([createdAt])
}
